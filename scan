#!/usr/bin/python
"This is mostly just a place to hold some recipes for cmd line scanning"

import random
import re
import shlex
import string
import subprocess
import sys

DEFAULT_RESOLUTION = 600
MODE = "Color"
DEBUG = False

def random_id():
    return ''.join(random.choices(string.ascii_lowercase, k=5))

def get_scanner_airscan_id():
    raw = subprocess.check_output(["scanimage", "-L"]).decode()
    for l in raw.split("\n"):
        l = l.strip()
        if "airscan:" in l:
            m = re.search(".*`(.*)'.*", l)
            if m:
                return m.group(1)

def main(resolution, scanner_id, out_filename):
    if DEBUG:
        print(scanner_id)
    print("Scanning. You may need to 'sudo apt remove ippusbxd'")
    print("If I have the wrong scanner, list them with 'scanimage -L'")
    output = out_filename + ".png"
    cmd = (
        "scanimage "
        "--format png "
        "--resolution " + str(resolution) + " "
        "--mode " + MODE + " "
        "-d \"" + scanner_id + "\" "
        "-o " + output + ""
    )
    if DEBUG:
        print(cmd)
    try:
        subprocess.check_output(shlex.split(cmd))
    except subprocess.CalledProcessError as e:
        print(e)

if __name__ == "__main__":
    resolution = sys.argv[1] if len(sys.argv) > 1 else DEFAULT_RESOLUTION
    out_filename = sys.argv[2] if len(sys.argv) > 2 else "scanned_" + random_id()
    scan_id = get_scanner_airscan_id()
    main(resolution, scan_id, out_filename)
